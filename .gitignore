# ── Dependencies ──────────────────────────────────────────────────────
node_modules/
dist/
build/

# ── Environment (never commit real secrets) ────────────────────────────
.env
.env.local
.env.production
# Allow frontend/.env.production — Firebase CLIENT keys are public-safe
# (security is enforced by Firebase authorized domains, not key secrecy)
!frontend/.env.production

# ── Uploads (user-uploaded images — back these up separately) ─────────
backend/uploads/*
!backend/uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────
backend/logs/
output/logs/
*.log

# ── OS & Editor ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/

# ── Stale output build ─────────────────────────────────────────────────
output/

# ── Utility / one-off scripts (contain JWT tokens — keep local only) ──
patch_images.js
repatch_images_unsplash.js
insert_2026_events.js
insert_2026_events.ps1
fix_events.js
seed_images.js
seed_images2.js

# ── Misc ──────────────────────────────────────────────────────────────
*.paint
mingit/

# ── Local Netlify folder ───────────────────────────────────────────────
.netlify
