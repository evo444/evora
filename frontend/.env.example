# ── Evora Frontend — Environment Variables ────────────────────────────
# Copy to .env (local) or paste into Vercel/Netlify dashboard.
# Vite exposes only variables prefixed with VITE_ to the browser.

# Your deployed backend URL (Render / Railway)
VITE_API_URL=https://evora-api.onrender.com

# For local development, use:
# VITE_API_URL=http://localhost:5000
