# ── Evora Backend — Environment Variables ────────────────────────────
# Copy this file to .env and fill in ALL values before starting.
# Never commit the real .env file to git.

# ── Server ────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production          # 'development' locally, 'production' on Render/Railway

# ── Database ──────────────────────────────────────────────────────────
# Get from: https://cloud.mongodb.com → Clusters → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/evora?retryWrites=true&w=majority

# ── Auth ──────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# ── CORS ──────────────────────────────────────────────────────────────
# Your deployed frontend URL (Vercel/Netlify).
# Comma-separated if you have multiple (e.g. preview + production).
FRONTEND_URL=https://evora.vercel.app

# ── Email (Resend API) ────────────────────────────────────────────────
# Sign up at https://resend.com (3,000 free emails/month)
# Create an API key and paste it below.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: verified sender domain (leave blank to use Resend sandbox)
# RESEND_FROM_EMAIL=noreply@yourdomain.com

# ── Admin Seed ────────────────────────────────────────────────────────
# Used only on first boot to create the admin account.
ADMIN_EMAIL=evora444@gmail.com
ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
